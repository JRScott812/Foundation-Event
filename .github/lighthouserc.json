{
  "ci": {
	"collect": {
	  "staticDistDir": "./_site",
	  "numberOfRuns": 1,
	  "url": [
		"http://localhost/index.html",
		"http://localhost/Events/5K/index.html",
		"http://localhost/Events/Haunted-House/index.html",
		"http://localhost/Events/Parade/index.html",
		"http://localhost/Contact-Us/index.html",
		"http://localhost/About-Us/index.html",
		"http://localhost/Legal/Privacy-Policy/index.html",
		"http://localhost/Legal/Terms-and-Conditions/index.html",
		"http://localhost/404.html"
	  ]
	},
	"upload": {
	  "target": "temporary-public-storage"
	},
	"assert": {
	  "preset": "lighthouse:recommended",
	  "assertions": {
		"cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
		"largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
		"first-input-delay": ["error", { "maxNumericValue": 100 }]
	  }
	}
  }
}
