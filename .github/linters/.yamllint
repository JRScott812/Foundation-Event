---
extends: default
rules:
  indentation:
    spaces: consistent
    indent-sequences: consistent
  comments:
    min-spaces-from-content: 1
  line-length:
    max: 120
  document-start: disable
  brackets:
    max-spaces-inside: 0
    min-spaces-inside: 0
  braces:
    max-spaces-inside: 0
    min-spaces-inside: 0
  trailing-spaces: disable
  new-lines:
    type: any