{
  "env": {
    "browser": true,
    "es2021": true
  },
  "globals": {
    "CONFIG": "readonly"
  },
  "extends": "eslint:recommended",
  "rules": {
    "no-undef": "off",
    "indent": ["error", "tab"],
    "semi": "off",
    "quotes": "off",
    "comma-dangle": "off",
    "space-before-function-paren": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  }
}
